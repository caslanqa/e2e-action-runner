# Copy this file to ".env" and fill in your token.
#
# Fine-grained Personal Access Token scoped to the target repository with:
#   - Repository access: caslanqa/e2e-action-runner
#   - Permissions:
#       Actions   -> Read and write   (trigger workflow + read runs/artifacts)
#       Contents  -> Read-only        (read the workflow YAML to build the form)
#       Metadata  -> Read-only        (always required)
GITHUB_TOKEN=

# Default target repo (can be overridden from the UI at runtime).
GITHUB_OWNER=
GITHUB_REPO=

# Local backend port (the Vite dev server proxies to this).
PORT=5179
